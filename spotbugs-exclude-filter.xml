<FindBugsFilter>
    <Match>
        <Bug code="EQ" pattern="EQ_CHECK_FOR_OPERAND_NOT_COMPATIBLE_WITH_THIS"/>
    </Match>
    <!--
        JPA 필드는 Hibernate가 리플렉션으로 읽고 씀 — orm.xml로 @Column 이동 후
        SpotBugs가 JPA 관리 필드임을 인식 못해 UWF_UNWRITTEN_FIELD 오탐.
    -->
    <Match>
        <Class name="~allmart\.orderservice\.domain\..*"/>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
</FindBugsFilter>