      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"color":{"mode":"palette-classic"},"min":0},
        "overrides": [
          {"matcher":{"id":"byName","options":"대기 중 (병목!)"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]},
