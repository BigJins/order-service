{
  "title": "allmart order-service 부하 테스트",
  "uid": "allmart-order-loadtest",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    { "type": "row", "title": "📊 k6 부하 테스트", "gridPos": {"h":1,"w":24,"x":0,"y":0}, "id": 100, "collapsed": false },

    {
      "id": 1, "title": "RPS (엔드포인트별)", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit":"reqps","color":{"mode":"palette-classic"}},"overrides":[]},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"list","placement":"bottom"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-service\",uri=~\"/api/orders.*\"}[30s])) by (method, uri)",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2, "title": "응답시간 최대값 (ms) — histogram 활성화 후 P95로 교체됨", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":12,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"unit":"ms","color":{"mode":"palette-classic"},
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":300},{"color":"red","value":1000}]}},
        "overrides":[]
      },
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"list","placement":"bottom"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"order-service\",uri=~\"/api/orders.*\"}[30s])) by (le, method, uri)) * 1000",
          "legendFormat": "P95 {{method}} {{uri}}",
          "refId": "A"
        },
        {
          "expr": "http_server_requests_seconds_max{application=\"order-service\",uri=~\"/api/orders.*\"} * 1000",
          "legendFormat": "MAX {{method}} {{uri}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 3, "title": "HTTP 상태코드별 요청 수", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":9},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"unit":"reqps","color":{"mode":"palette-classic"}},
        "overrides": [
          {"matcher":{"id":"byFrameRefID","options":"C"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]
      },
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"list","placement":"bottom"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-service\",status=~\"2..\"}[30s]))",
          "legendFormat": "2xx 성공",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-service\",status=~\"4..\"}[30s]))",
          "legendFormat": "4xx 클라이언트 에러",
          "refId": "B"
