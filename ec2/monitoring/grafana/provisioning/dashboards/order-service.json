{
  "title": "allmart order-service 부하 테스트",
  "uid": "allmart-order-loadtest",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    { "type": "row", "title": "📊 k6 부하 테스트 결과", "gridPos": {"h":1,"w":24,"x":0,"y":0}, "id": 100, "collapsed": false },

    {
      "id": 1, "title": "RPS (초당 요청 수)", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"unit":"reqps","color":{"mode":"palette-classic"}},
        "overrides": []
      },
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"list","placement":"bottom"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-service\"}[30s])) by (uri, method)",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2, "title": "응답시간 P95 (ms)", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":12,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"unit":"ms","color":{"mode":"palette-classic"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":300},{"color":"red","value":500}]}},
        "overrides": []
      },
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"list","placement":"bottom"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"order-service\",uri=~\"/api/orders.*\"}[30s])) by (le, uri, method)) * 1000",
          "legendFormat": "P95 {{method}} {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"order-service\",uri=~\"/api/orders.*\"}[30s])) by (le, uri, method)) * 1000",
          "legendFormat": "P50 {{method}} {{uri}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 3, "title": "에러율 (%)", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":9},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"unit":"percent","min":0,"max":100,"color":{"mode":"fixed","fixedColor":"red"}},
        "overrides": []
      },
      "options": {"tooltip":{"mode":"multi"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-service\",status=~\"5..\"}[30s])) / sum(rate(http_server_requests_seconds_count{application=\"order-service\"}[30s])) * 100",
          "legendFormat": "5xx 에러율",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-service\",status=~\"4..\"}[30s])) / sum(rate(http_server_requests_seconds_count{application=\"order-service\"}[30s])) * 100",
          "legendFormat": "4xx 에러율",
          "refId": "B"
        }
      ]
    },

    {
      "id": 4, "title": "k6 VU 수 & 처리량", "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":12,"y":9},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {"color":{"mode":"palette-classic"}},
        "overrides": [
          {"matcher":{"id":"byName","options":"VU 수"},"properties":[{"id":"custom.axisPlacement","value":"right"}]}
